NODE_ENV=development
PORT=5000
# Frontend URL used inside shop QR codes.
APP_BASE_URL=http://localhost:5173
# Production example:
# APP_BASE_URL=https://qrmart-01.onrender.com
CORS_ORIGIN=http://localhost:5173,https://qrmart-01.onrender.com

MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/qrmart?retryWrites=true&w=majority&appName=Cluster0

# Local development: point this to your Firebase service account JSON.
FIREBASE_SERVICE_ACCOUNT_PATH=./your-firebase-adminsdk.json

# Deployment alternative: paste base64-encoded service account JSON instead of using a file.
FIREBASE_SERVICE_ACCOUNT_BASE64=

ADMIN_API_KEY=replace-with-a-long-random-value
OWNER_API_KEY=replace-with-a-long-random-value
JWT_SECRET=replace-with-a-long-random-jwt-secret

# Google Sign-In. You can either set the client ID directly or point to a Google OAuth client JSON file.
GOOGLE_CLIENT_ID=326409235411-m2v9butg0bib4vhkl3sb8vdqat6hghsu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_FILE=frontend/client_secret_326409235411-m2v9butg0bib4vhkl3sb8vdqat6hghsu.apps.googleusercontent.com.json
